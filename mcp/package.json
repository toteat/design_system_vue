{
  "name": "@toteat-eng/design-system-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing @toteat-eng/design-system-vue API for Claude",
  "type": "module",
  "bin": {
    "design-system-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "sync:icons": "tsx scripts/sync-icons.ts",
    "sync:tokens": "tsx scripts/sync-tokens.ts",
    "sync:components": "tsx scripts/generate-components.ts",
    "generate": "tsx scripts/sync-icons.ts && tsx scripts/sync-tokens.ts && tsx scripts/generate-components.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http --port 3333",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vitest": "^3.1.3"
  }
}
